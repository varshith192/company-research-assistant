# Serper.dev API key — used for search (resolving official websites, contact
# details, and competitor discovery). Get one at https://serper.dev
SERPER_API_KEY=

# OpenRouter API key — used for all AI analysis.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Port to listen on (Render sets this automatically in production).
PORT=4000
