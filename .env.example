# Base URL of the backend API server (see /server). Locally this is the
# Express server started with `npm run dev` inside /server (default port
# 4000). In production, set this to your deployed Render service URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Discord bot token and channel ID are NOT configured here. They are entered
# at runtime from the app's Settings dialog (Discord Integration tab) and
# stored only in the browser's localStorage, per the assignment spec.

# Note: SERPER_API_KEY and OPENROUTER_API_KEY are no longer configured in
# this frontend project — they live in /server/.env (see server/.env.example),
# since all API/AI logic now runs in the standalone backend.
